<?xml version="1.0" encoding="utf-8"?>
<config>
  <insertAfter xpath="/blocks/block[@name='spawnTrader']">
    <block name="spawnTraderRekt">
      <property name="Extends" value="spawnTrader"/>
      <property name="CreativeMode" value="None"/>
      <property name="SpawnClass" value="npcTraderRekt" />
    </block>
    <block name="spawnTraderJen">
      <property name="Extends" value="spawnTrader"/>
      <property name="CreativeMode" value="None"/>

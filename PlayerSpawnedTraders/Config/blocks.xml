      <property name="CustomIcon" value="signTraderRektExteriorLarge"/>
      <property name="DescriptionKey" value="traderRektPlaceableDesc"/>
      <property name="Class" value="PlantGrowing" />
      <property class="PlantGrowing">
        <property name="IsGrowOnTopEnabled" value="false"/>
        <property name="Next" value="spawnTraderRekt"/>
        <property name="FertileLevel" value="0"/>
        <property name="LightLevelGrow" value="0"/>
        <property name="LightLevelStay" value="0"/>
        <property name="IsRandom" value="false"/>

      <property name="PlaceAltBlockValue" value="traderRektPlaceable,traderJenPlaceable,traderBobPlaceable,traderHughPlaceable,traderJoelPlaceable"/>
      <property name="SellableToTrader" value="false"/>
      <property name="SortOrder1" value="U200"/>
      <property name="SortOrder2" value="0000"/>
      <property name="FilterTags" value="MC_playerBlocks,SC_playerHelpers"/>

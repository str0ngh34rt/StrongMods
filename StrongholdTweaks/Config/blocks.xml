  <!-- Warp pads are returned when destroyed -->
  <append xpath="/blocks/block[@name='warpPadBlockSecure']">
    <dropextendsoff/>
    <drop event="Destroy" name="warpPadBlockSecure" count="1"/>
    <drop event="Fall" name="warpPadBlockSecure" count="1" prob=".9" stick_chance=".9"/>
  </append>
  <append xpath="/blocks/block[@name='warpPadBlockPortable']">
    <dropextendsoff/>
    <drop event="Destroy" name="warpPadBlockPortable" count="1"/>
    <drop event="Fall" name="warpPadBlockPortable" count="1" prob=".9" stick_chance=".9"/>
  </append>

  <!-- All blocks not explicitly set as unstackable will stack to 65k. -->
  <setattribute xpath="/blocks/block/property[@name='Stacknumber'][@value > 1]" name="value">65000</setattribute>
  <append xpath="/blocks//block[not(property[@name='Stacknumber'])]">  <!-- Default: 500 -->
    <property name="Stacknumber" value="65000" />
  </append>

</config>

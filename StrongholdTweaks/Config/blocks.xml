      <property name="PlantGrowing.GrowthRate" value="16" />
      <property name="Material" value="Mbedrock" />
      <property name="Group" value="StrongCrops" />
      <drop event="Destroy" name="plantedMushroom1" count="0" />
    </block>
    <block name="plantedStrongMushroom2">
      <property name="Extends" value="plantedMushroom2" />
      <property name="CreativeMode" value="None"/>
      <property name="PlantGrowing.Next" value="plantedStrongMushroom3Harvest" />
      <property name="PlantGrowing.GrowthRate" value="16" />
      <property name="Material" value="Mbedrock" />
      <property name="Group" value="StrongCrops" />
      <drop event="Destroy" name="plantedMushroom1" count="0" />
    </block>
    <block name="plantedStrongMushroom3Harvest">
      <property name="Extends" value="plantedMushroom3HarvestPlayer" />
      <property name="CreativeMode" value="None"/>
      <property name="DescriptionKey" value="plantedStrongMushroom3Harvest"/>
      <property name="DowngradeBlock" value="plantedStrongMushroom1"/>
      <property name="Group" value="StrongCrops" />
      <dropextendsoff />
      <drop event="Harvest" name="foodCropMushrooms" count="4" tag="cropHarvest"/>
      <drop event="Harvest" name="foodCropMushrooms" prob="0.5" count="1" tag="bonusCropHarvest"/>
      <drop event="Harvest" name="foodCropMushrooms" count="1" tag="farmerBonusHarvest"/>

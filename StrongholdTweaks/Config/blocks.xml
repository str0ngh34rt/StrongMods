<config>

  <!-- Remove all tree seed drops -->
  <remove xpath="/blocks/block/drop[starts-with(@name, 'treePlanted')]" />

  <!-- Workstations and Campfires allow all rotations -->
  <remove xpath="/blocks/block[property[@name='Class'][@value='Workstation' or @value='Campfire']]/property[@name='OnlySimpleRotations']" />
  <setattribute xpath="/blocks/block[property[@name='Class'][@value='Workstation' or @value='Campfire']]/property[@name='AllowedRotations']" name="value">All</setattribute>
  <append xpath="/blocks/block[property[@name='Class'][@value='Workstation' or @value='Campfire']][not(property[@name='AllowedRotations'])]">
    <property name="AllowedRotations" value="All" />
  </append>

  <!-- StrongStones -->
  <append xpath="/blocks">
    <block name="block_strongstone">
      <property name="CreativeMode" value="None" />
      <property name="Class" value="GameEvent" />
      <property name="ActivateEvent" value="event_strongstone" />
      <property name="CustomIcon" value="twitchHordeStone01" />
      <property name="CustomIconTint" value="00ff00" />
      <property name="Material" value="Mstone" />
      <property name="Shape" value="ModelEntity" />
      <property name="Model" value="@:Entities/OutdoorDecor/graveStoneSpawnerPrefab.prefab" />
      <property name="MultiBlockDim" value="1,2,1" />
      <property name="ModelOffset" value="0,0,0" />
      <property name="DestroyOnEvent" value="false" />
      <drop event="Destroy" name="block_strongstone_variant_helper" count="1" />
      <drop event="Destroy" count="0" />
    </block>

    <block name="block_strongstone_elite">
      <property name="Extends" value="block_strongstone" />
      <property name="CreativeMode" value="None" />
      <property name="ActivateEvent" value="event_strongstone_elite" />
    </block>

    <block name="block_strongstone_variant_helper">
      <property name="Extends" value="block_strongstone" />
      <property name="CreativeMode" value="Player" />
      <property name="ItemTypeIcon" value="all_blocks" />
      <property name="SelectAlternates" value="true" />
      <property name="PlaceAltBlockValue" value="block_strongstone,block_strongstone_elite" />
    </block>
  </append>


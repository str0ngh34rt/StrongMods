<?xml version="1.0" encoding="utf-8"?>
<config>
  <remove xpath="/worldglobal/environment/property[@class='blood_rain']" />
  <append xpath="/worldglobal/environment">
    <property class="blood_rain">
      <property name="schedule_irl" value="0 4,13,20 * * *" />
      <property name="duration_irl_minutes" value="20" />
      <property name="countdown_irl_minutes" value="15" />
      <property name="min_game_day" value="15" />
      <property name="second_warning_message" value="[00ff00]The chat command [ff0000]/horde[-] will teleport you to the community horde base.[-]" />
      <property name="party_enemy_count_max" value="64" />
    </property>
    <property class="strong_protected_difficulty_tiers_by_biome">
      <property name="default" value="1"/>
      <property name="pine_forest" value="1"/>
      <property name="burnt_forest" value="2"/>
      <property name="desert" value="3"/>
      <property name="snow" value="4"/>
      <property name="wasteland" value="4"/>
    </property>
  </append>
</config>

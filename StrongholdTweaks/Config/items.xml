<config>

  <conditional>
    <if cond="mod_loaded('ChristmasCookbook')">
      <include filename="items_xmas_cooking.xml" />
    </if>
  </conditional>

  <!-- Schematics that have been read show a green "read" icon -->
  <setattribute xpath="/items/item[@name='schematicMaster']/property[@name='AltItemTypeIconColor']" name="value">0,255,0,200</setattribute>
  <append xpath="/items/item[@name='schematicMaster' and not(property[@name='AltItemTypeIconColor'])]">
    <property name="AltItemTypeIconColor" value="0,255,0,200" />
  </append>

  <!-- Master Tool compatibility with Project Z
       with patch: 11, 17
       without patch: 18, 28
       impact driver: 17, 13
       salvagingSkill   :  Buffs harvest based on the Perfection Salvaging skill
       ImprovedParsing  :  Allows salvaging mods to be put in the tool
  <csv xpath="/items/item[@name='meleeMasterTool']/property[@name='Tags']/@value" delim="," op="add">salvagingSkill,ImprovedParsing</csv>
       -->

  <!-- Stronghold intro quests -->
  <append xpath="/items">
    <item name="noteIntroToHades">
      <property name="Extends" value="blankNoteMaster"/>
      <property name="CreativeMode" value="Player"/>
      <property name="DescriptionKey" value="readTheNote"/>
      <property name="CustomIcon" value="challengeQuestMaster"/>
      <property name="CustomIconTint" value="ff6a02" />
      <property name="NoScrapping" value="true"/>
      <property name="SoundPickup" value="map_grab"/>
      <property name="SoundPlace" value="map_place"/>
      <property class="Action0">
        <property name="Class" value="Eat"/>
        <property name="Delay" value="1.0"/>
        <!-- <property name="UseAnimation" value="false"/> -->
        <property name="Sound_start" value="read_mod"/>
        <property name="Sound_in_head" value="true"/>
        <property name="PromptTitle" value="noteIntroToHades"/>
        <property name="PromptDescription" value="noteIntroToHadesDesc"/>
      </property>
      <effect_group tiered="false">
        <triggered_effect trigger="onSelfPrimaryActionEnd" action="GiveExp" exp="100"/>
      </effect_group>
    </item>
    <item name="map_stronghold">
      <property name="Extends" value="questMaster" />
      <property name="CreativeMode" value="Player" />
      <property name="CustomIcon" value="treasureQuestMaster" />
      <property name="CustomIconTint" value="ff6a02" />
      <property name="ItemTypeIcon" value="quest" />
      <property name="DescriptionKey" value="map_stronghold_desc" />
      <property name="NoScrapping" value="true" />
      <property name="Stacknumber" value="1" />
      <property class="Action0">
        <property name="Class" value="Quest" />
        <property name="QuestGiven" value="quest_find_stronghold" />
        <property name="Delay" value="1" />
        <property name="UseAnimation" value="false" />
      </property>
    </item>
  </append>

  <append xpath="/items">
    <item name="item_opal_of_ophelia">
      <property name="Extends" value="casinoCoin" />
      <property name="CustomIcon" value="foodEgg" />
      <property name="CustomIconTint" value="ff6a02" />
      <property name="DescriptionKey" value="item_opal_of_ophelia_desc" />
      <property name="CreativeMode" value="None" />  <!-- Hide Opals for Season 6 -->
      <property name="EconomicValue" value="0" />
      <property class="Action0">
        <property name="Class" value="Eat" />
        <property name="Delay" value="0" />
        <property name="UseAnimation" value="false" />
      </property>
      <effect_group tiered="false">
        <triggered_effect trigger="onSelfPrimaryActionEnd" action="ModifyCVar" cvar="pending_fast_travel_donations" operation="add" value="1" />
      </effect_group>
    </item>
  </append>

  <!-- All items not explicitly set as unstackable will stack to 65k. -->
  <setattribute xpath="/items/item/property[@name='Stacknumber'][@value > 1]" name="value">65000</setattribute>
  <append xpath="/items//item[not(starts-with(@name, 'vehicle') and contains(@name, 'Placeable')) and not(property[@name='Stacknumber'])]">  <!-- Default: 500 -->
    <property name="Stacknumber" value="65000" />
  </append>

</config>

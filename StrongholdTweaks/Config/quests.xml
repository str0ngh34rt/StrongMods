<config>
  <!-- Stronghold intro quests -->
  <append xpath="/quests">
    <quest id="quest_find_stronghold">
      <property name="name_key" value="quest_find_stronghold" />
      <property name="description_key" value="quest_find_stronghold_desc" />
      <property name="offer_key" value="quest_find_stronghold_offer" />
      <property name="subtitle_key" value="quest_find_stronghold_subtitle" />
      <property name="statement_key" value="quest_find_stronghold_statement" />
      <property name="response_key" value="quest_find_stronghold_response" />
      <property name="completion_key" value="quest_find_stronghold_completion" />
      <property name="icon" value="ui_game_symbol_quest" />
      <property name="category_key" value="quest" />
      <property name="repeatable" value="true" />
      <property name="shareable" value="false" />
      <property name="add_to_tier_complete" value="false" />

      <objective type="Goto" value="5" phase="1">
        <property name="location_tag" value="find_stronghold" />
        <property name="location_name" value="Stronghold" />
        <property name="nav_object" value="quest" />
        <property name="biome_filter_type" value="AnyBiome" />
      </objective>

      <objective type="StatAwarded" phase="2">
        <property name="stat_name" value="stronghold_visited" />
        <property name="stat_text" value="Enter Stronghold" />
        <property name="count" value="1" />
      </objective>

      <action type="ShowMessageWindow">
        <property name="message" value="quest_stronghold_found_description" />
        <property name="title" value="quest_stronghold_found_description_title" />
        <property name="on_complete" value="true" />
      </action>

      <action type="SetCVar">
        <property name="cvar" value="can_tp_to_stronghold" />
        <property name="value" value="1" />
        <property name="on_complete" value="true" />
      </action>

      <reward type="Exp" value="500" />
      <reward type="Item" id="aecIMTutorialBook" value="1" />
      <reward type="Item" id="ironDoorBlockVariantHelper" value="1" />
      <reward type="Item" id="ironHatchBlockVariantHelper" value="1" />
      <reward type="Item" id="cntSteelWritableCrate" value="5" />
      <reward type="Item" id="lanternDecorLightBlockVariantHelper" value="2" />
      <reward type="Item" id="cntVendingMachine" value="3" />
      <reward type="Item" id="toolCookingPot" value="1" />
      <reward type="Item" id="meleeToolPaintToolAdmin" value="1" />
    </quest>
  </append>
  <append xpath="/quests/quest[@id='quest_whiteRiverCitizen1']">
    <reward type="Item" id="map_stronghold" value="1" />
  </append>
</config>

<config>
  <!-- Edit player entity to increase health and stamina -->
  <set xpath="/entity_classes/entity_class[@name='playerMale']/effect_group/passive_effect[@name='HealthMax'][@value='100']/@value">200</set>  <!-- default = 100 -->
  <set xpath="/entity_classes/entity_class[@name='playerMale']/effect_group/passive_effect[@name='StaminaMax'][@value='100']/@value">200</set>  <!-- default = 100 -->
  <insertAfter xpath="/entity_classes/entity_class[@name='playerMale']/effect_group/passive_effect[@name='StaminaMax']">
    <triggered_effect trigger="onSelfFirstSpawn" action="AddBuff" target="self" buff="buffEntitySpawnHeal" />
  </insertAfter>

  <!-- Adjust starter items -->
  <csv xpath="/entity_classes/entity_class[@name='playerMale']/property[@class='ItemsOnEnterGame']/property/@value" delim="," op="remove">
    drinkJarBoiledWater,drinkJarBoiledWater=2,foodCanChili,medicalFirstAidBandage,noteDuke01,aecIMTutorialBook
  </csv>
  <csv xpath="/entity_classes/entity_class[@name='playerMale']/property[@class='ItemsOnEnterGame']/property/@value" delim="," op="add">
    foodBaconAndEggs=5,drinkJarYuccaJuice=5,medicalFirstAidBandage=5
  </csv>
  <insertAfter xpath="/entity_classes/entity_class[@name='playerMale']/property[@class='ItemsOnEnterGame']">
    <!-- These items should go to your backpack instead of your toolbar so that they can't be deleted on death -->
    <property class="BackpackItemsOnEnterGame">
      <property name="GameModeSurvival" value="map_stronghold,aecIMTutorialBook" />
      <property name="GameModeSurvivalSP" value="map_stronghold,aecIMTutorialBook" />
      <property name="GameModeSurvivalMP" value="map_stronghold,aecIMTutorialBook" />
    </property>
  </insertAfter>

  <conditional>
    <if cond="mod_loaded('ProjectZ') or mod_loaded('Z_Bosses')">
      <!-- The mini-boss loot container is super hard to see, so change it to a red z-pack -->
      <setattribute xpath="/entity_classes/entity_class[@name='MiniBossLootContainer']/property[@name='Mesh']" name="value">@:Entities/LootContainers/zpackRedPrefab.prefab
      </setattribute>

      <append xpath="/entity_classes/entity_class[@name='ChargedEliteLootContainer']">
        <property name="loot_item_name_strong" value="item_loot_container_charged_elite_strong" />
      </append>
      <append xpath="/entity_classes/entity_class[@name='InfernalEliteLootContainer']">
        <property name="loot_item_name_strong" value="item_loot_container_infernal_elite_strong" />
      </append>
      <append xpath="/entity_classes/entity_class[@name='smallMiniBossLootContainer']">
        <property name="loot_item_name_strong" value="item_loot_container_small_mini_boss_strong" />
      </append>
      <append xpath="/entity_classes/entity_class[@name='MiniBossLootContainer']">
        <property name="loot_item_name_strong" value="item_loot_container_mini_boss_strong" />
      </append>
      <append xpath="/entity_classes/entity_class[@name='BossLootContainerShocker']">
        <property name="loot_item_name_strong" value="item_loot_container_boss_shocker_strong" />
      </append>
      <append xpath="/entity_classes/entity_class[@name='BossLootContainerMutantHog']">
        <property name="loot_item_name_strong" value="item_loot_container_boss_mutant_hog_strong" />
      </append>
      <append xpath="/entity_classes/entity_class[@name='BossLootContainerBull']">
        <property name="loot_item_name_strong" value="item_loot_container_boss_bull_strong" />
      </append>
      <append xpath="/entity_classes/entity_class[@name='BossLootContainerVeteran']">
        <property name="loot_item_name_strong" value="item_loot_container_boss_veteran_strong" />
      </append>
      <append xpath="/entity_classes/entity_class[@name='BossLootContainerAncientYeti']">
        <property name="loot_item_name_strong" value="item_loot_container_boss_ancient_yeti_strong" />
      </append>
      <append xpath="/entity_classes/entity_class[@name='BossLootContainerCarrier']">
        <property name="loot_item_name_strong" value="item_loot_container_boss_carrier_strong" />
      </append>
    </if>
  </conditional>

  <append xpath="/entity_classes">
    <entity_class name="animalRabbitGolf" extends="animalRabbit">
      <property name="AITask-1" value="Look" />
      <property name="AITask-2" value="" /> <!-- The first empty AI Task ends the list -->
      <!--<property name="MatColor" value="charged"/>-->
      <effect_group name="Base Effects">
        <passive_effect name="HealthMax" operation="base_set" value="99999" />
      </effect_group>
    </entity_class>
    <entity_class name="animalChickenGolf" extends="animalChicken">
      <property name="AITask-1" value="Look" />
      <property name="AITask-2" value="" /> <!-- The first empty AI Task ends the list -->
      <!--<property name="MatColor" value="charged"/>-->
      <effect_group name="Base Effects">
        <passive_effect name="HealthMax" operation="base_set" value="99999" />
      </effect_group>
    </entity_class>
  </append>

</config>

<?xml version="1.0" encoding="utf-8"?>
<config>
  <!-- Rotting flesh and mutation samples shouldn't smell. If they did, zombies would fight each other when alive. -->
  <remove xpath="/items/item[@name='resourceMutationSamples' or @name='foodRottingFlesh']/property[@name='Smell']" />

  <!-- Scrapping is too slow, make it slightly faster but not so fast that you can't cancel an accidental scrap -->
  <setattribute xpath="/items/item/property[@name='ScrapTimeOverride'][@value=10]" name="value">7</setattribute>
  <setattribute xpath="/items/item/property[@name='ScrapTimeOverride'][@value=15]" name="value">10</setattribute>
</config>

<configs>
  <append xpath="/items">

    <item name="resourceTinkle">
      <property name="CustomIcon" value="drinkJarRiverWater" />
      <property name="CustomIconTint" value="255,255,0" />
      <property name="HoldType" value="3" />
      <property name="Meshfile" value="@:Other/Items/Food/bottled_waterPrefab.prefab" />
      <property name="DropMeshfile" value="@:Other/Items/Misc/sack_droppedPrefab.prefab" />
      <property name="Material" value="Mglass" />
      <property name="Stacknumber" value="500" />
      <property name="EconomicValue" value="0" />
      <property name="SellableToTrader" value="false" />
      <property name="Group" value="Resources,Chemicals" />
      <property name="DescriptionKey" value="resourceTinkleDesc" />
    </item>

    <item name="resourceDookie">
      <property name="CustomIcon" value="twitchTurd" />
      <property name="HoldType" value="3" />

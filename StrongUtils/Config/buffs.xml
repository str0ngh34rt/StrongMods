<?xml version="1.0" encoding="utf-8"?>
<config>
  <append xpath="/buffs">
    <buff name="buff_strongsworn"
          name_key="buff_strongsworn_name"
          description_key="buff_strongsworn_desc"
          icon="ui_game_symbol_strength_mastery"
          icon_color="0,200,0">
      <stack_type value="ignore" />
    </buff>
    <buff name="buff_not_strongsworn"
          name_key="buff_not_strongsworn_name"
          description_key="buff_not_strongsworn_desc"
          icon="ui_game_symbol_strength_mastery"
          icon_color="200,200,0">
      <stack_type value="ignore" />
    </buff>
    <buff name="buff_strongsworn_zone_violation"
          name_key="buff_strongsworn_zone_violation_name"
          description_key="buff_strongsworn_zone_violation_desc"
          tooltip_key="buff_strongsworn_zone_violation_tooltip"
          icon="ui_game_symbol_strength_mastery"
          icon_color="200,0,0">
      <duration value="10" />
      <stack_type value="replace" />
      <effect_group>
        <triggered_effect trigger="onSelfBuffStart" action="PlaySound" sound="sysadmin_security_breach"/>
      </effect_group>
    </buff>
    <buff name="buff_no_hostiles_zone_violation">
      <stack_type value="ignore" />
      <effect_group>
        <triggered_effect trigger="onSelfBuffStart" action="ModifyCVar" cvar="$SniperDamage" operation="set" value="200"/>
        <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="buff_no_hostiles_zone_violation_shoot"/>
        <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="buff_no_loot"/>
      </effect_group>
    </buff>
    <buff name="buff_no_hostiles_zone_violation_shoot">
      <update_rate value="0.5"/>
      <effect_group>
        <triggered_effect trigger="onSelfBuffStart" action="AddBuff" buff="buff_no_hostiles_zone_violation_shock"/>
        <triggered_effect trigger="onSelfBuffStart" action="PlaySound" sound="sharpshooter_fire"/>
        <triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buff_no_hostiles_zone_violation_damage"/>
        <triggered_effect trigger="onSelfBuffUpdate" action="RemoveBuff" buff="buff_no_hostiles_zone_violation_shoot"/>
      </effect_group>
    </buff>
    <buff name="buff_no_hostiles_zone_violation_damage">
      <update_rate value="0.1"/>
      <effect_group>
        <!--<triggered_effect trigger="onSelfBuffStart" action="Ragdoll" duration="10"/>-->
        <triggered_effect trigger="onSelfBuffStart" action="ModifyStats" stat="Health" operation="subtract" value="@$SniperDamage"/>
        <triggered_effect trigger="onSelfBuffUpdate" action="ModifyCVar" cvar="$SniperDamage" operation="multiply" value="2"/>
        <triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buff_no_hostiles_zone_violation_shoot"/>
        <triggered_effect trigger="onSelfBuffUpdate" action="RemoveBuff" buff="buff_no_hostiles_zone_violation_damage"/>
      </effect_group>
    </buff>
    <buff name="buff_no_hostiles_zone_violation_shock">
      <stack_type value="duration"/>
      <duration value="5"/>
      <effect_group>
        <triggered_effect trigger="onSelfBuffStart" action="AttachParticleEffectToEntity" particle="p_electric_shock" parent_transform="Spine1" local_offset="0,-.2,0"/>
        <triggered_effect trigger="onSelfEnteredGame" action="AttachParticleEffectToEntity" particle="p_electric_shock" parent_transform="Spine1" local_offset="0,-.2,0"/>

        <triggered_effect trigger="onSelfDied" action="RemoveParticleEffectFromEntity" particle="p_electric_shock"/>
        <triggered_effect trigger="onSelfBuffRemove" action="RemoveParticleEffectFromEntity" particle="p_electric_shock"/>

        <triggered_effect trigger="onSelfBuffFinish" action="RemoveParticleEffectFromEntity" particle="p_electric_shock"/>
        <triggered_effect trigger="onSelfBuffRemove" action="RemoveParticleEffectFromEntity" particle="p_electric_shock"/>
        <triggered_effect trigger="onSelfBuffRemove" action="RemoveCVar" cvar="ETrapHit"/>
        <triggered_effect trigger="onSelfLeaveGame" action="RemoveParticleEffectFromEntity" particle="p_electric_shock"/>

        <triggered_effect trigger="onSelfBuffStart" action="PlaySound" sound="electric_fence_impact"/>
        <triggered_effect trigger="onSelfBuffRemove" action="FadeOutSound" sound="electric_fence_impact"/>
        <triggered_effect trigger="onSelfLeaveGame" action="StopSound" sound="electric_fence_impact"/>

        <passive_effect name="RunSpeed" operation="perc_subtract" value="1,1" duration="0,5"/>
        <passive_effect name="WalkSpeed" operation="perc_subtract" value="1,1" duration="0,5"/>
        <passive_effect name="CrouchSpeed" operation="perc_subtract" value="1,1" duration="0,5"/>
        <passive_effect name="JumpStrength" operation="perc_subtract" value="1,1" duration="0,5"/>
      </effect_group>
    </buff>
    <!-- Marker buff that when applied to an entity makes it so they drop no loot on death. -->
    <buff name="buff_no_loot" remove_on_death="false">
      <stack_type value="ignore"/>
    </buff>
    <buff name="buff_no_claims"
          name_key="buff_no_claims_name"
          description_key="buff_no_claims_desc"
          icon="ui_game_symbol_twitch_no_placing_land_claim"
          icon_color="200,200,0">
      <stack_type value="ignore" />
      <effect_group>
        <passive_effect name="DisableItem" operation="base_set" value="1" tags="landclaim" />
      </effect_group>
    </buff>
    <buff name="buff_no_claims_violation"
          name_key="buff_no_claims_violation_name"
          description_key="buff_no_claims_violation_desc"
          tooltip_key="buff_no_claims_violation_tooltip"
          icon="ui_game_symbol_twitch_no_placing_land_claim"
          icon_color="200,0,0">
      <duration value="10" />
      <stack_type value="replace" />
      <effect_group>
        <triggered_effect trigger="onSelfBuffStart" action="PlaySound" sound="keystone_build_warning"/>
      </effect_group>
    </buff>
  </append>

  <append xpath="/buffs/buff[@name='buffStatusCheck01']">
    <effect_group name="StrongSworn">
      <requirement name="CVarCompare" cvar="strongsworn" operation="Equals" value="1"/>
      <triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buff_strongsworn">
        <requirement name="!HasBuff" buff="buff_strongsworn"/>
      </triggered_effect>
      <triggered_effect trigger="onSelfBuffUpdate" action="RemoveBuff" buff="buff_not_strongsworn">
        <requirement name="HasBuff" buff="buff_not_strongsworn"/>
      </triggered_effect>
    </effect_group>
    <effect_group name="NotStrongSworn">
      <requirement name="CVarCompare" cvar="strongsworn" operation="NotEquals" value="1"/>
      <triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buff_not_strongsworn">
        <requirement name="!HasBuff" buff="buff_not_strongsworn"/>
      </triggered_effect>
      <triggered_effect trigger="onSelfBuffUpdate" action="RemoveBuff" buff="buff_strongsworn">
        <requirement name="HasBuff" buff="buff_strongsworn"/>
      </triggered_effect>
    </effect_group>
  </append>
</config>

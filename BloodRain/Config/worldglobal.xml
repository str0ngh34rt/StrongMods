<?xml version="1.0" encoding="utf-8"?>
<config>
  <append xpath="/worldglobal/environment">
    <!--
      schedule_irl takes a cron expression. Times are in the operating system's configured time zone.

                                             Allowed values    Allowed special characters   Comment
        ┌───────────── minute                0-59              * , - /
        │ ┌───────────── hour                0-23              * , - /
        │ │ ┌───────────── day of month      1-31              * , - / L W ?
        │ │ │ ┌───────────── month           1-12 or JAN-DEC   * , - /
        │ │ │ │ ┌───────────── day of week   0-6  or SUN-SAT   * , - / # L ?                Both 0 and 7 mean SUN
        │ │ │ │ │
        * * * * *

      Examples:
        0 20 * * *     Every day @ 8 PM
        */10 * * * *   Every 10 minutes (!!)
        0 12 * * 0,3   Every Wed and Sun @ noon
    -->
    <property class="blood_rain">
      <property name="schedule_irl" value="0 20 * * *" /> <!-- daily at 8 PM -->
      <property name="duration_irl_minutes" value="15" /> <!-- blood rain lasts for 15 minutes -->
      <property name="countdown_irl_minutes" value="15" /> <!-- broadcast a warning in game every minute for 15 minutes prior to the start of the blood rain -->
      <property name="min_game_day" value="7" /> <!-- skip blood rain if countdown starts on day < 7 -->
      <property name="second_warning_message" value="" /> <!-- sent to general after each message saying how many minutes until blood rain -->
      <property name="party_enemy_count_max" value="30" /> <!-- the max total enemies that can spawn on any "party" during the blood rain -->
    </property>
  </append>
</config>

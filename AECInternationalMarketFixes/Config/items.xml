<?xml version="1.0" encoding="utf-8"?>
<config>
  <conditional>
    <if cond="mod_loaded('AEC_InternationalMarket')">
      <append xpath="/items">
        <item name="aecIMTutorialBook">
          <property name="Extends" value="questMaster" />
          <property name="DescriptionKey" value="aecIMTutorialBookDesc" />
          <property name="CustomIcon" value="challengeQuestMaster" />
          <property name="Stacknumber" value="1" />
          <property class="Action0">
            <property name="Class" value="Quest" />
            <property name="QuestGiven" value="aec_im_tutorial" />
            <property name="Delay" value="0.5" />
            <property name="UseAnimation" value="false" />
          </property>
        </item>
      </append>
    </if>
  </conditional>
</config>
